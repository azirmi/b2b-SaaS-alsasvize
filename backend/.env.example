# =============================================================================
#  Backend environment template — copy to ".env" and adjust as needed.
#  Local defaults below mirror the root docker-compose.yml.
# =============================================================================

# ----- PostgreSQL (Prisma datasource) ---------------------------------------
DATABASE_URL="postgresql://visa_admin:visa_local_password@localhost:5433/visa_management?schema=public"

# ----- MinIO (S3-compatible object storage) ---------------------------------
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minio_admin"
MINIO_SECRET_KEY="minio_local_password"
MINIO_BUCKET="visa-documents"

# ----- Application ----------------------------------------------------------
NODE_ENV="development"
PORT="3001"

# ----- Auth (JWT) -----------------------------------------------------------
# Use a long, random secret in production, e.g. `openssl rand -base64 48`.
JWT_SECRET="change-me"
# ms-style duration string (e.g. "15m", "1d", "7d").
JWT_EXPIRES_IN="1d"

# ----- SLA ------------------------------------------------------------------
# Hours an application may sit in one stage before it counts as an SLA breach.
SLA_THRESHOLD_HOURS="48"
# Hours a claimed application may sit in SALES_PROCESS before the SLA cron
# auto-reverts it to SALES_POOL (frees the stalled task back to the pool).
SLA_SALES_PROCESS_HOURS="2"

# ----- Real-time (Socket.io) ------------------------------------------------
# Comma-separated allow-list of browser origins allowed to open a WebSocket.
# Leave unset in local dev (the gateway reflects the request origin instead).
CORS_ORIGIN="http://localhost:3000"

# ----- Email (SMTP / nodemailer) --------------------------------------------
# Self-hosted transactional email. Leave SMTP_HOST unset to disable sending
# entirely (useful in local dev — the service logs instead of delivering).
# Port 465 uses implicit TLS (SMTPS); any other port negotiates STARTTLS.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Envelope "From" address shown to recipients (falls back to SMTP_USER).
SMTP_FROM="Alsasvize <no-reply@alsasvize.local>"
# Absolute URL of the Alsas Vize logo shown at the top of every email
# (email clients require an absolute URL). Falls back to the company domain.
EMAIL_LOGO_URL="https://alsasvize.com/logo.png"
# Customer portal login URL used in email CTA buttons.
CUSTOMER_LOGIN_URL="https://alsasvize.com/login"

# ----- Dijizin (KVKK OTP + forms) ------------------------------------------
DIJIZIN_BASE_URL="https://api.dijizin.com"
DIJIZIN_CLIENT_ID="019f4739-8af6-733b-a3dd-96cf039600d0"
DIJIZIN_CLIENT_SECRET="OUrDYq7th5E7lPquDTBCQSj5zCZSuPgTj9rlGMk7rh5xpJiQvPKFYHIkCt0eGyUB"
DIJIZIN_REQUEST_TIMEOUT_MS="15000"
